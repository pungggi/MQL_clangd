.git/**
.vscode/**
.gitignore
.gitattributes
# Webpack bundles all dependencies - exclude node_modules entirely
node_modules/**
# Exclude source files - only ship bundled dist
src/**
test/**
scripts/**
# ...but ship the chart-arranger worker: it is a runtime asset loaded from
# extensionPath/scripts, not bundled by webpack.
!scripts/mt5-arrange-charts.ps1
.agent/**
package-lock.json
*.log
# Exclude webpack config from package
webpack.config.js
# Exclude compile_commands.json — this is generated per-workspace by the extension.
# Shipping the dev workspace's copy causes clangd to load a second, stale database.
compile_commands.json
